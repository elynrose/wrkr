# Database (local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=homepro

# Railway: add MySQL plugin and use the generated MYSQL_URL (no need to set DB_*)

PORT=3001
NODE_ENV=development

JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES=7d

# Frontend URL (for CORS). On Railway set to your frontend URL, e.g. https://your-app.up.railway.app
FRONTEND_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional
MATCH_NOTIFY_COUNT=8
MATCH_EXPIRY_HOURS=4
