# HomePro API — Environment Variables
# Copy to .env and fill in your values

# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=homepro

# Or use a single connection URL instead:
# DATABASE_URL=mysql://user:password@localhost:3306/homepro

# ── Server ──────────────────────────────────────────────
PORT=3001

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES=7d

# ── Frontend / Site URL (for emails, Stripe redirects, claim links, sitemap) ─
FRONTEND_URL=http://localhost:5173
# SITE_URL overrides BASE_URL for sitemap/robots when different from FRONTEND_URL

# ── Stripe (payments, subscriptions, credits) ───────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Twilio (SMS for lead matching) ──────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15551234567

# Optional: override match engine defaults
# MATCH_NOTIFY_COUNT=8
# MATCH_EXPIRY_HOURS=4

# ── Superadmin (tenant signup) ───────────────────────────
SUPERADMIN_SECRET=your-superadmin-secret

# ── CORS (optional, comma-separated origins) ──────────────
# ALLOWED_ORIGINS=https://yoursite.com,https://app.yoursite.com
